<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/calculator_background"
    android:fillViewport="true"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="156dp"
            android:background="@drawable/bg_display_panel"
            android:elevation="2dp"
            android:gravity="bottom"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="14dp">

            <TextView
                android:id="@+id/tv_expression"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="start"
                android:gravity="end"
                android:maxLines="1"
                android:text="0"
                android:textColor="@color/display_expression"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/tv_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="end"
                android:text="0"
                android:textColor="@color/display_result"
                android:textSize="42sp"
                android:textStyle="bold" />

        </LinearLayout>

        <GridLayout
            android:id="@+id/calculator_grid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:alignmentMode="alignMargins"
            android:columnCount="4"
            android:rowCount="5"
            android:useDefaultMargins="false">

            <Button
                android:id="@+id/btn_clear_entry"
                style="@style/CalculatorFunctionButton"
                android:layout_width="0dp"
                android:layout_height="68dp"
                android:layout_columnWeight="1"
                android:text="CE"
                android:textSize="18sp" />

            <Button
                android:id="@+id/btn_divide"
                style="@style/CalculatorOperatorButton"
                android:layout_width="0dp"
                android:layout_height="68dp"
                android:layout_columnWeight="1"
                android:text="÷"
                android:textSize="24sp" />

            <Button
                android:id="@+id/btn_multiply"
                style="@style/CalculatorOperatorButton"
                android:layout_width="0dp"
                android:layout_height="68dp"
                android:layout_columnWeight="1"
                android:text="×"
                android:textSize="24sp" />

            <Button
                android:id="@+id/btn_clear_all"
                style="@style/CalculatorFunctionButton"
                android:layout_width="0dp"
                android:layout_height="68dp"
                android:layout_columnWeight="1"
                android:text="C"
                android:textSize="18sp" />

            <Button
                android:id="@+id/btn_7"
                style="@style/CalculatorNumberButton"
                android:layout_width="0dp"
                android:layout_height="68dp"
                android:layout_columnWeight="1"
                android:text="7"
                android:textSize="24sp" />

            <Button
                android:id="@+id/btn_8"
                style="@style/CalculatorNumberButton"
                android:layout_width="0dp"
                android:layout_height="68dp"
                android:layout_columnWeight="1"
                android:text="8"
                android:textSize="24sp" />

            <Button
                android:id="@+id/btn_9"
                style="@style/CalculatorNumberButton"
                android:layout_width="0dp"
                android:layout_height="68dp"
                android:layout_columnWeight="1"
                android:text="9"
                android:textSize="24sp" />

            <Button
                android:id="@+id/btn_add"
                style="@style/CalculatorOperatorButton"
                android:layout_width="0dp"
                android:layout_height="68dp"
                android:layout_columnWeight="1"
                android:text="+"
                android:textSize="24sp" />

            <Button
                android:id="@+id/btn_4"
                style="@style/CalculatorNumberButton"
                android:layout_width="0dp"
                android:layout_height="68dp"
                android:layout_columnWeight="1"
                android:text="4"
                android:textSize="24sp" />

            <Button
                android:id="@+id/btn_5"
                style="@style/CalculatorNumberButton"
                android:layout_width="0dp"
                android:layout_height="68dp"
                android:layout_columnWeight="1"
                android:text="5"
                android:textSize="24sp" />

            <Button
                android:id="@+id/btn_6"
                style="@style/CalculatorNumberButton"
                android:layout_width="0dp"
                android:layout_height="68dp"
                android:layout_columnWeight="1"
                android:text="6"
                android:textSize="24sp" />

            <Button
                android:id="@+id/btn_subtract"
                style="@style/CalculatorOperatorButton"
                android:layout_width="0dp"
                android:layout_height="68dp"
                android:layout_columnWeight="1"
                android:text="-"
                android:textSize="24sp" />

            <Button
                android:id="@+id/btn_1"
                style="@style/CalculatorNumberButton"
                android:layout_width="0dp"
                android:layout_height="68dp"
                android:layout_columnWeight="1"
                android:text="1"
                android:textSize="24sp" />

            <Button
                android:id="@+id/btn_2"
                style="@style/CalculatorNumberButton"
                android:layout_width="0dp"
                android:layout_height="68dp"
                android:layout_columnWeight="1"
                android:text="2"
                android:textSize="24sp" />

            <Button
                android:id="@+id/btn_3"
                style="@style/CalculatorNumberButton"
                android:layout_width="0dp"
                android:layout_height="68dp"
                android:layout_columnWeight="1"
                android:text="3"
                android:textSize="24sp" />

            <ImageButton
                android:id="@+id/btn_sqrt"
                style="@style/CalculatorFunctionIconButton"
                android:layout_width="0dp"
                android:layout_height="68dp"
                android:layout_columnWeight="1"
                android:contentDescription="@string/sqrt_button"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_sqrt" />

            <Button
                android:id="@+id/btn_reciprocal"
                style="@style/CalculatorFunctionButton"
                android:layout_width="0dp"
                android:layout_height="68dp"
                android:layout_columnWeight="1"
                android:text="1/X"
                android:textSize="15sp" />

            <Button
                android:id="@+id/btn_0"
                style="@style/CalculatorNumberButton"
                android:layout_width="0dp"
                android:layout_height="68dp"
                android:layout_columnWeight="1"
                android:text="0"
                android:textSize="24sp" />

            <Button
                android:id="@+id/btn_decimal"
                style="@style/CalculatorNumberButton"
                android:layout_width="0dp"
                android:layout_height="68dp"
                android:layout_columnWeight="1"
                android:text="."
                android:textSize="24sp" />

            <Button
                android:id="@+id/btn_equals"
                style="@style/CalculatorEqualsButton"
                android:layout_width="0dp"
                android:layout_height="68dp"
                android:layout_columnWeight="1"
                android:text="="
                android:textSize="24sp" />

        </GridLayout>

    </LinearLayout>

</ScrollView>
