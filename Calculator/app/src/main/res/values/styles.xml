<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="CalculatorButtonBase" parent="@style/Widget.AppCompat.Button">
        <item name="android:layout_margin">5dp</item>
        <item name="android:gravity">center</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:paddingLeft">0dp</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingRight">0dp</item>
        <item name="android:paddingBottom">0dp</item>
        <item name="android:singleLine">true</item>
        <item name="android:maxLines">1</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/button_text</item>
        <item name="backgroundTint">@null</item>
    </style>

    <style name="CalculatorNumberButton" parent="@style/CalculatorButtonBase">
        <item name="android:background">@drawable/bg_calc_number_key</item>
    </style>

    <style name="CalculatorFunctionButton" parent="@style/CalculatorButtonBase">
        <item name="android:background">@drawable/bg_calc_function_key</item>
    </style>

    <style name="CalculatorOperatorButton" parent="@style/CalculatorButtonBase">
        <item name="android:background">@drawable/bg_calc_operator_key</item>
    </style>

    <style name="CalculatorEqualsButton" parent="@style/CalculatorButtonBase">
        <item name="android:background">@drawable/bg_calc_equals_key</item>
        <item name="android:textColor">@color/button_equals_text</item>
    </style>

    <style name="CalculatorIconButtonBase" parent="@style/Widget.AppCompat.ImageButton">
        <item name="android:layout_margin">5dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:paddingLeft">18dp</item>
        <item name="android:paddingTop">18dp</item>
        <item name="android:paddingRight">18dp</item>
        <item name="android:paddingBottom">18dp</item>
        <item name="android:tint">@color/button_text</item>
        <item name="backgroundTint">@null</item>
    </style>

    <style name="CalculatorFunctionIconButton" parent="@style/CalculatorIconButtonBase">
        <item name="android:background">@drawable/bg_calc_function_key</item>
    </style>

</resources>
