<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_activated="true">
        <shape>
            <solid android:color="@color/chapter07_primary" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <item android:state_selected="true">
        <shape>
            <solid android:color="@color/chapter07_primary" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/chapter07_surface" />
            <corners android:radius="14dp" />
            <stroke
                android:width="1dp"
                android:color="@color/chapter07_stroke" />
        </shape>
    </item>
</selector>
