<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/chapter07_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/chapter07_surface"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@android:color/white"
        android:gravity="center_vertical"
        android:paddingHorizontal="18dp">

        <TextView
            android:id="@+id/tv_chapter07_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/back_symbol"
            android:textColor="#0F172A"
            android:textSize="30sp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="114dp"
                android:layout_height="wrap_content"
                android:text="@string/chapter07_ledger_title"
                android:textColor="#0F172A"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="63dp"
                android:layout_height="wrap_content"
                android:text="@string/chapter07_title"
                android:textColor="@color/chapter07_text_secondary"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_chapter07"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        app:tabIndicatorColor="@color/chapter07_primary"
        app:tabIndicatorFullWidth="false"
        app:tabRippleColor="@android:color/transparent"
        app:tabSelectedTextColor="@color/chapter07_primary"
        app:tabTextColor="@color/chapter07_text_secondary" />

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/vp_chapter07"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
