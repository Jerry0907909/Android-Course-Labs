<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_chapter07_panel"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/chapter07_month_select"
            android:textColor="#0F172A"
            android:textSize="14sp"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/sp_bill_month"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_chapter07_input"
            android:paddingHorizontal="12dp"
            android:prompt="@string/chapter07_spinner_prompt" />

        <TextView
            android:id="@+id/tv_bill_summary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:textColor="@color/chapter07_text_secondary"
            android:textSize="13sp" />
    </LinearLayout>

    <ListView
        android:id="@+id/lv_bill_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="14dp"
        android:divider="@android:color/transparent"
        android:dividerHeight="8dp" />

    <TextView
        android:id="@+id/tv_bill_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:gravity="center"
        android:text="@string/chapter07_empty"
        android:textColor="@color/chapter07_text_secondary"
        android:textSize="15sp" />

</LinearLayout>
