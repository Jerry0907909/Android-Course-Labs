<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/chapter06_cart_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FBFF"
    android:orientation="vertical"
    tools:context=".Chapter06CartActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@android:color/white"
        android:gravity="center_vertical"
        android:paddingHorizontal="18dp">

        <TextView
            android:id="@+id/tv_cart_back"
            android:layout_width="32dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/back_symbol"
            android:textColor="#0F172A"
            android:textSize="30sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/chapter06_cart_page_title"
            android:textColor="#0F172A"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_cart_page_count"
            android:layout_width="42dp"
            android:layout_height="26dp"
            android:background="@drawable/bg_chapter06_badge"
            android:gravity="center"
            android:textColor="#3964FE"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E2E8F0" />

    <ListView
        android:id="@+id/lv_cart"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:cacheColorHint="@android:color/transparent"
        android:divider="@android:color/transparent"
        android:dividerHeight="10dp"
        android:listSelector="@android:color/transparent"
        android:paddingHorizontal="18dp"
        android:paddingTop="10dp"
        android:paddingBottom="24dp"
        android:scrollbars="none" />

        <LinearLayout
            android:id="@+id/ll_cart_empty"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:paddingHorizontal="18dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_cart_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/chapter06_cart_empty_tip"
                android:textColor="#64748B"
                android:textSize="18sp" />

            <Button
                android:id="@+id/btn_shopping_channel"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_chapter06_button_secondary"
                android:backgroundTint="@null"
                android:text="@string/chapter06_go_shopping"
                android:textAllCaps="false"
                android:textColor="#3964FE"
                android:textSize="16sp"
                app:backgroundTint="@null" />
        </LinearLayout>

    <TextView
        android:id="@+id/tv_cart_storage_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#F8FBFF"
        android:paddingHorizontal="18dp"
        android:paddingTop="6dp"
        android:paddingBottom="4dp"
        android:textColor="#64748B"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="18dp"
        android:paddingTop="12dp"
        android:paddingBottom="18dp">

        <Button
            android:id="@+id/btn_cart_clear"
            android:layout_width="92dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_chapter06_button_secondary"
            android:backgroundTint="@null"
            android:text="@string/chapter06_clear"
            android:textAllCaps="false"
            android:textColor="#3964FE"
            android:textSize="16sp"
            app:backgroundTint="@null" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/chapter06_total_label"
                android:textColor="#64748B"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_cart_total_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="#DC2626"
                android:textSize="30sp"
                android:textStyle="bold" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_cart_checkout"
            android:layout_width="92dp"
            android:layout_height="44dp"
            android:layout_marginStart="14dp"
            android:background="@drawable/bg_chapter06_action"
            android:backgroundTint="@null"
            android:text="@string/chapter06_checkout"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            app:backgroundTint="@null" />
    </LinearLayout>
</LinearLayout>
